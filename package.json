{
  "name": "startos-joplin",
  "description": "Joplin Server packaged for StartOS — a self-hosted sync backend for Joplin notes, with a bundled PostgreSQL sidecar.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nfealey/startos-joplin.git"
  },
  "scripts": {
    "build": "rm -rf ./javascript && ncc build startos/index.ts -o ./javascript",
    "prettier": "prettier --write startos",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@start9labs/start-sdk": "1.5.3"
  },
  "devDependencies": {
    "@types/node": "22.19.0",
    "@vercel/ncc": "0.38.4",
    "prettier": "3.6.2",
    "typescript": "5.9.3"
  },
  "prettier": {
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true
  }
}
